{
  "agent_meta": {
    "name": "求职智能体",
    "version": "5.0.0",
    "framework": "AutoClaw",
    "llm_backend": "GLM-4-Plus",
    "description": "围绕学生学习生活与职业发展的全自动求职智能体，支持跨应用协作（浏览器 → Excel → Word），含模拟面试评估",
    "author": "AutoClaw Framework",
    "architecture": "路径B：原生 Skill 模式 | GLM 调度 + AutoClaw 执行 + Skill 原子能力"
  },

  "skill_registry": {
    "ocr_extractor": {
      "module": "skills.ocr_extractor",
      "class": "OCRExtractorSkill",
      "description": "证书 OCR 提取 Skill：从证书照片中识别文字，提取证书名称、时间、机构、技能等结构化数据。",
      "input_schema": {
        "image_paths": "list[string]"
      },
      "output_schema": {
        "experiences": "list[ExperienceItem]",
        "count": "integer"
      },
      "trigger_phrases": ["证书识别", "从照片提取", "证书OCR"]
    },
    "jd_analyzer": {
      "module": "skills.jd_analyzer",
      "class": "JDAnalyzerSkill",
      "description": "JD 分析 Skill：从岗位 JD 文本中提取硬技能、软素质、学历、出勤要求。",
      "input_schema": {
        "jd_text": "string",
        "target_role": "string"
      },
      "output_schema": {
        "jd_keywords": "list[string]",
        "jd_hard_skills": "list[string]",
        "jd_soft_skills": "list[string]",
        "jd_degree_req": "string",
        "jd_summary": "string"
      },
      "trigger_phrases": ["分析JD", "岗位要求", "这个岗位需要什么"]
    },
    "experience_extractor": {
      "module": "skills.experience_extractor",
      "class": "ExperienceExtractorSkill",
      "description": "经历萃取 Skill：从非结构化文本/草稿/证书描述中，提取时间、角色、核心成就。",
      "input_schema": {
        "raw_text": "string",
        "target_role": "string"
      },
      "output_schema": {
        "experiences": "list[ExperienceItem]"
      },
      "trigger_phrases": ["帮我整理经历", "提取我的经历", "这是我的草稿"]
    },
    "star_polisher": {
      "module": "skills.star_polisher",
      "class": "StarPolisherSkill",
      "description": "亮点打磨 Skill：按照 STAR 原则重构经历描述，结合 JD 关键词精准覆盖。",
      "input_schema": {
        "experiences": "list[ExperienceItem]",
        "target_role": "string",
        "jd_keywords": "list[string]"
      },
      "output_schema": {
        "polished_md": "string",
        "keyword_coverage": "float"
      },
      "trigger_phrases": ["润色简历", "用STAR重写", "让我的经历更职业"],
      "glm_delegation": "STAR 改写属语义密集型任务，生产环境由 GLM 完成"
    },
    "resume_writer": {
      "module": "skills.resume_writer",
      "class": "ResumeWriterSkill",
      "description": "排版适配 Skill：填充标准化简历模板，导出 Word 文件。",
      "input_schema": {
        "polished_md": "string",
        "user_profile": "UserProfile",
        "target_role": "string"
      },
      "output_schema": {
        "file_path": "string",
        "status": "string"
      },
      "trigger_phrases": ["生成简历", "导出Word", "帮我写成简历文件"],
      "cross_app": {
        "write_to": "Microsoft Word (.docx)",
        "output_dir": "output/"
      }
    },
    "job_scraper": {
      "module": "skills.web_job_scraper",
      "class": "JobScraperSkill",
      "description": "数据抓取 Skill：驱动 AutoClaw WebDriver 自动翻页，跨平台并发抓取岗位信息。",
      "input_schema": {
        "keyword": "string",
        "city": "string",
        "platforms": "list[string]",
        "max_pages": "integer"
      },
      "output_schema": {
        "jobs": "list[JobItem]",
        "total_count": "integer"
      },
      "trigger_phrases": ["帮我找实习", "搜索岗位", "抓取招聘信息"],
      "cross_app": {
        "read_from": "Browser (zhipin.com, shixiseng.com, etc.)",
        "tool": "AutoClaw_WebDriver / MCP_WebReader"
      }
    },
    "match_scorer": {
      "module": "skills.match_scorer",
      "class": "MatchScorerSkill",
      "description": "匹配评分 Skill：四维评分体系（技能/出勤/城市/学历），输出 Tier 分级。",
      "input_schema": {
        "jobs": "list[JobItem]",
        "user_profile": "UserProfile"
      },
      "output_schema": {
        "scored_jobs": "list[ScoredJobItem]"
      },
      "trigger_phrases": ["哪个岗位更适合我", "帮我打分", "筛选岗位"],
      "glm_delegation": "JD 匹配属语义密集型任务，生产环境由 GLM 完成"
    },
    "report_generator": {
      "module": "skills.report_generator",
      "class": "ReportGeneratorSkill",
      "description": "跨应用写数 Skill：写入 Excel 对比表（条件格式、冻结行、匹配色）。",
      "input_schema": {
        "scored_jobs": "list[ScoredJobItem]",
        "output_path": "string"
      },
      "output_schema": {
        "file_path": "string",
        "status": "string"
      },
      "trigger_phrases": ["生成对比表", "导出Excel", "给我一个分析报告"],
      "cross_app": {
        "write_to": "Microsoft Excel (.xlsx)",
        "output_dir": "output/"
      }
    },
    "academic_search": {
      "module": "skills.academic_search",
      "class": "AcademicSearchSkill",
      "description": "学术搜索 Skill：通过 AutoClaw MCP_WebReader 搜索学术论文，返回标题、作者、摘要、引用数。",
      "input_schema": {
        "research_topic": "string",
        "max_results": "integer"
      },
      "output_schema": {
        "papers": "list[PaperItem]",
        "total_count": "integer"
      },
      "trigger_phrases": ["搜索论文", "文献搜索", "帮我找论文"]
    },
    "paper_digest": {
      "module": "skills.paper_digest",
      "class": "PaperDigestSkill",
      "description": "文献提炼 Skill：对论文摘要进行结构化提取（核心观点、方法论、结论），生成综述 Markdown。",
      "input_schema": {
        "papers": "list[PaperItem]",
        "research_topic": "string"
      },
      "output_schema": {
        "digested_papers": "list[DigestedPaper]",
        "review_md": "string",
        "trends": "list[string]"
      },
      "trigger_phrases": ["分析论文", "提炼文献", "写综述"],
      "glm_delegation": "文献提炼属语义密集型任务，生产环境由 GLM 完成"
    },
    "literature_report": {
      "module": "skills.literature_report",
      "class": "LiteratureReportSkill",
      "description": "文献综述报告生成 Skill：将文献数据生成 Word 报告（含论文表格、趋势分析、研究建议）。",
      "input_schema": {
        "digested_papers": "list[DigestedPaper]",
        "topic": "string"
      },
      "output_schema": {
        "file_path": "string",
        "format": "string"
      },
      "trigger_phrases": ["生成文献报告", "导出文献综述"],
      "cross_app": {
        "write_to": "Microsoft Word (.docx)",
        "output_dir": "output/"
      }
    },
    "interview_questioner": {
      "module": "skills.interview_questioner",
      "class": "InterviewQuestionerSkill",
      "description": "面试出题 Skill：根据目标岗位能力模型，生成结构化面试题（技术/行为/综合）。",
      "input_schema": {
        "target_role": "string",
        "resume_data": "string",
        "interview_type": "string",
        "num_questions": "integer"
      },
      "output_schema": {
        "questions": "list[InterviewQuestion]",
        "total_count": "integer"
      },
      "trigger_phrases": ["面试题", "模拟面试", "帮我准备面试", "出题"],
      "glm_delegation": "面试出题属语义密集型任务，生产环境由 GLM 完成"
    },
    "interview_scorer": {
      "module": "skills.interview_scorer",
      "class": "InterviewScorerSkill",
      "description": "面试评估 Skill：四维评分体系（完整度/条理性/STAR/关键词），输出改进建议与示范回答。",
      "input_schema": {
        "question": "string",
        "answer": "string",
        "reference_points": "list[string]",
        "target_role": "string"
      },
      "output_schema": {
        "score": "integer",
        "tier": "string",
        "dimensions": "dict",
        "feedback": "list[string]",
        "improved_answer": "string"
      },
      "trigger_phrases": ["评估回答", "帮我打分", "面试评分"],
      "glm_delegation": "面试评估属语义密集型任务，生产环境由 GLM 完成"
    },
    "interview_report": {
      "module": "skills.interview_report",
      "class": "InterviewReportSkill",
      "description": "面试报告 Skill：汇总问答与评分数据，生成 Word 练习报告（含维度分析、改进建议）。",
      "input_schema": {
        "interview_results": "list[InterviewResult]",
        "target_role": "string",
        "output_path": "string"
      },
      "output_schema": {
        "file_path": "string",
        "summary": "dict"
      },
      "trigger_phrases": ["生成面试报告", "面试练习报告"],
      "cross_app": {
        "write_to": "Microsoft Word (.docx)",
        "output_dir": "output/"
      }
    }
  },

  "task_pipelines": {
    "resume_generation": {
      "name": "个性化简历生成流（JD 定制）",
      "description": "案例2：从经历草稿 → JD 分析 → STAR 打磨 → Word 简历",
      "trigger": "用户提供经历草稿 + 目标岗位 JD",
      "steps": [
        {
          "step": 1,
          "skill": "jd_analyzer",
          "label": "JD 分析与关键词提取",
          "description": "解析目标岗位 JD，提取硬技能、软素质、学历要求"
        },
        {
          "step": 2,
          "skill": "experience_extractor",
          "label": "经历萃取",
          "description": "解析原始草稿，提取时间、角色、关键行为"
        },
        {
          "step": 3,
          "skill": "star_polisher",
          "label": "STAR 亮点打磨（JD 定制）",
          "description": "结合 JD 关键词，用 STAR 原则重构每条经历"
        },
        {
          "step": 4,
          "skill": "resume_writer",
          "label": "排版适配与导出",
          "description": "填充 Word 模板，保存至 output/ 目录"
        }
      ],
      "output": "output/{target_role}_定向简历.docx"
    },
    "resume_with_ocr": {
      "name": "证书识别 + 简历生成流",
      "description": "从证书照片 → OCR 识别 → 经历萃取 → STAR 打磨 → Word 简历",
      "trigger": "用户提供证书照片 + 目标岗位",
      "steps": [
        {
          "step": 1,
          "skill": "ocr_extractor",
          "label": "证书照片 OCR 识别",
          "description": "识别证书照片中的文字，提取结构化经历"
        },
        {
          "step": 2,
          "skill": "jd_analyzer",
          "label": "JD 分析",
          "description": "解析目标岗位 JD"
        },
        {
          "step": 3,
          "skill": "star_polisher",
          "label": "STAR 亮点打磨",
          "description": "结合 JD 关键词打磨证书经历"
        },
        {
          "step": 4,
          "skill": "resume_writer",
          "label": "排版导出",
          "description": "填充 Word 模板"
        }
      ],
      "output": "output/{target_role}_证书简历.docx"
    },
    "internship_aggregator": {
      "name": "实习职位自动聚合流",
      "description": "案例3：从岗位抓取到实习申请对比表",
      "trigger": "用户输入目标城市+目标岗位关键词",
      "steps": [
        {
          "step": 1,
          "skill": "job_scraper",
          "label": "跨平台岗位抓取",
          "description": "并发抓取 BOSS、实习僧等平台"
        },
        {
          "step": 2,
          "skill": "match_scorer",
          "label": "智能匹配评分",
          "description": "对比用户画像，对每个岗位打匹配分"
        },
        {
          "step": 3,
          "skill": "report_generator",
          "label": "生成 Excel 对比表",
          "description": "写入 Excel，条件格式高亮"
        }
      ],
      "output": "output/{city}_{keyword}_实习对比表.xlsx"
    },
    "literature_research": {
      "name": "全自动文献调研流",
      "description": "典型场景：自动搜索论文 → 结构化提炼 → 生成 Word 文献综述报告",
      "trigger": "用户输入研究主题关键词",
      "steps": [
        {
          "step": 1,
          "skill": "academic_search",
          "label": "学术论文搜索",
          "description": "通过 AutoClaw MCP_WebReader 搜索相关论文"
        },
        {
          "step": 2,
          "skill": "paper_digest",
          "label": "文献结构化提炼",
          "description": "提取核心观点、方法论、结论，生成综述 Markdown"
        },
        {
          "step": 3,
          "skill": "literature_report",
          "label": "生成 Word 文献综述报告",
          "description": "将提炼数据生成 Word 报告（含论文表格、趋势分析、研究建议）"
        }
      ],
      "output": "output/{topic}_文献综述报告.docx"
    },
    "full_job_hunting": {
      "name": "完整求职全流程",
      "description": "一键完成简历生成 + 岗位聚合的完整链路",
      "trigger": "用户希望一站式完成简历与岗位匹配",
      "fail_fast": false,
      "steps": [
        { "step": 1, "pipeline": "resume_generation" },
        { "step": 2, "pipeline": "internship_aggregator" }
      ],
      "output": [
        "output/{target_role}_定向简历.docx",
        "output/{city}_{keyword}_实习对比表.xlsx"
      ]
    },
    "interview_practice": {
      "name": "模拟面试练习流",
      "description": "根据目标岗位生成面试题 → 用户作答 → 评估反馈 → 生成报告（需交互式执行）",
      "trigger": "用户输入目标岗位，要求面试练习",
      "interactive": true,
      "steps": [
        {
          "step": 1,
          "skill": "interview_questioner",
          "label": "面试题生成",
          "description": "基于岗位能力模型生成结构化面试题"
        }
      ],
      "output": "output/{target_role}_面试练习报告.docx"
    },
    "resume_and_interview": {
      "name": "简历 + 面试一站式",
      "description": "先生成简历，再基于简历内容进行面试练习",
      "trigger": "用户希望一站式完成简历与面试准备",
      "fail_fast": false,
      "steps": [
        { "step": 1, "pipeline": "resume_generation" },
        { "step": 2, "pipeline": "interview_practice" }
      ],
      "output": [
        "output/{target_role}_定向简历.docx",
        "output/{target_role}_面试练习报告.docx"
      ]
    }
  },

  "cross_app_workflow": {
    "description": "跨应用协作链路（Browser → GLM → Excel → Word）",
    "chain": [
      {
        "step": 1,
        "app": "Browser",
        "action": "AutoClaw WebDriver 抓取招聘页面；OCR 识别证书照片"
      },
      {
        "step": 2,
        "app": "GLM (LLM)",
        "action": "调度 JD Analyzer 解析岗位要求；STAR Polisher 改写经历；Match Scorer 语义评分；Paper Digest 文献提炼"
      },
      {
        "step": 3,
        "app": "Microsoft Excel",
        "action": "Report Generator 写入 Excel 对比表"
      },
      {
        "step": 4,
        "app": "Microsoft Word",
        "action": "Resume Writer 生成简历；Literature Report 生成文献综述"
      }
    ]
  },

  "llm_dispatch_rules": {
    "description": "GLM 调度规则：根据用户意图路由至对应 Pipeline",
    "routing": [
      {
        "intent": "简历生成",
        "keywords": ["写简历", "生成简历", "经历草稿", "管培生", "校招", "JD", "岗位要求"],
        "pipeline": "resume_generation"
      },
      {
        "intent": "证书简历",
        "keywords": ["证书", "照片", "OCR", "证书识别"],
        "pipeline": "resume_with_ocr"
      },
      {
        "intent": "岗位聚合",
        "keywords": ["找实习", "搜岗位", "对比表", "上海", "北京", "抓取"],
        "pipeline": "internship_aggregator"
      },
      {
        "intent": "文献调研",
        "keywords": ["文献", "论文", "调研", "学术", "研究"],
        "pipeline": "literature_research"
      },
      {
        "intent": "完整流程",
        "keywords": ["一站式", "帮我找工作", "全套", "完整流程"],
        "pipeline": "full_job_hunting"
      },
      {
        "intent": "面试练习",
        "keywords": ["面试", "模拟面试", "面经", "面试题", "面试准备", "面试练习"],
        "pipeline": "interview_practice"
      },
      {
        "intent": "简历面试一站式",
        "keywords": ["简历面试", "全套准备", "简历加面试"],
        "pipeline": "resume_and_interview"
      }
    ],
    "fallback": "由 GLM 直接回答，不触发 Pipeline"
  },

  "runtime_settings": {
    "output_dir": "output/",
    "assets_dir": "assets/",
    "user_profile_path": "assets/user_resume.json",
    "log_level": "INFO",
    "max_concurrent_scrape": 3,
    "request_delay_ms": 1500,
    "supported_platforms": ["zhipin", "shixiseng", "nowcoder", "liepin", "lagou"]
  }
}
